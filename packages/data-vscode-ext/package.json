{
  "name": "@gi-tcg/data-vscode-ext",
  "displayName": "Genius Invokation TCG Data Code Extension",
  "description": "Just add magical text decorations to @gi-tcg/data package's source",
  "publisher": "Guyutongxue",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.96.0"
  },
  "type": "commonjs",
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "onLanguage:typescript"
  ],
  "main": "./dist/extension.js",
  "contributes": {},
  "scripts": {
    "vscode:prepublish": "pnpm build",
    "build:method_names": "gnx scripts/get_method_names.mts",
    "build:ts": "tsdown",
    "build": "pnpm build:method_names && pnpm build:ts",
    "watch": "pnpm build:ts --watch",
    "package": "pnpm && gnx scripts/publish.mts",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@gi-tcg/core": "workspace:*",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.9.1",
    "rxjs": "^7.8.1"
  },
  "dependencies": {
    "execa": "catalog:"
  }
}
